# Waline 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# JWT Token（必需）- 用于加密，32位随机字符串
JWT_TOKEN=your_32_character_random_string_here

# 数据库配置（选择一种）
# MongoDB（推荐）
MONGO_DB=mongodb+srv://username:password@cluster.mongodb.net/waline

# LeanCloud（备选）
# LEAN_ID=your_leancloud_app_id
# LEAN_KEY=your_leancloud_app_key
# LEAN_MASTER_KEY=your_leancloud_master_key

# 站点配置
SITE_NAME=BruceLee Blog
SITE_URL=https://swkajnbruceee.github.io

# 管理员邮箱（可选）
ADMIN_EMAIL=your-email@example.com

# 安全域名限制
SECURE_DOMAINS=swkajnbruceee.github.io

# 邮件通知配置（可选）
# SMTP_SERVICE=gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SENDER_NAME=BruceLee Blog
# SENDER_EMAIL=your-email@gmail.com

# 功能开关
DISABLE_REGION=false
DISABLE_USERAGENT=false